for contact in contacts
  a.contact-item.animate-on-scroll-enter(href=(contact.url || '#') class=contact.name.toLowerCase().replace(/\s+/g, '-'))
    div.icon-wrapper
      if contact.lottie
        canvas.lottie-canvas(data-src=contact.lottie)
      else if contact.svg
        img.contact-svg(src=contact.svg alt=contact.name)
    span #{contact.name}
    //- In your layout.pug (e.g. head or bottom of body)
script(type="module", defer).
  import { DotLottie } from 'https://esm.sh/@lottiefiles/dotlottie-web';

  document.querySelectorAll('canvas.lottie-canvas').forEach(canvas => {
    const src  = canvas.dataset.src;
    const player = new DotLottie({
      canvas,
      src,
      autoplay: false
    });

    player.addEventListener('load', () => {
      const wrapper = canvas.closest(".contact-item");
      wrapper.addEventListener("mouseenter", () => {
        player.setMode("forward")

        player.play();
      });
      wrapper.addEventListener("mouseleave", () => {
        player.setMode("reverse");

        player.play();
      });
    });
  });

            